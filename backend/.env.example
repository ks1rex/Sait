# ============================================================
# AI Provider
# ============================================================

# Активный провайдер: deepseek | openai
AI_PROVIDER=deepseek

# DeepSeek API (используется по умолчанию)
DEEPSEEK_API_KEY=sk-...

# OpenAI API (альтернативный провайдер — раскомментировать при переключении)
# OPENAI_API_KEY=sk-...

# ============================================================
# Supabase
# ============================================================

# URL проекта Supabase (Settings → API → Project URL)
SUPABASE_URL=https://<project-ref>.supabase.co

# Service Role Key — даёт доступ в обход RLS; хранить строго в секрете
# (Settings → API → Project API keys → service_role)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# JWT Secret для верификации токенов пользователей
# (Settings → API → JWT Settings → JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret

# ============================================================
# Backend
# ============================================================

# Порт, на котором запускается Uvicorn (по умолчанию 8000)
BACKEND_PORT=8000

# Разрешённые CORS-источники через запятую (для продакшена — домен фронтенда)
# В режиме разработки можно оставить *
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Путь к исполняемому файлу LibreOffice (для конвертации docx → pdf).
# Windows (локальная разработка):
# LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
# Linux / Docker (soffice уже в PATH после apt install libreoffice):
# LIBREOFFICE_PATH=soffice
# Если переменная не задана — используется "soffice" (ищется в системном PATH).
LIBREOFFICE_PATH=soffice
